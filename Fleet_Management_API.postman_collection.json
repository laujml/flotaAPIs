{
  "info": {
    "name": "Fleet Management API - Vehicles & Maintenance",
    "description": "Complete API workflow for vehicle fleet management including CRUD operations, maintenance scheduling, and efficiency reporting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('auth_token', jsonData.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@fleet.local\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles - Complete Lifecycle",
      "item": [
        {
          "name": "1. Create Vehicle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"plate\": \"TRUCK-123\", \"type\": \"truck\", \"capacity\": 5000, \"currentOdometer\": 50000}"
            },
            "url": {
              "raw": "http://localhost:3000/vehicles",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["vehicles"]
            }
          }
        },
        {
          "name": "2. Get All Vehicles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/vehicles",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["vehicles"]
            }
          }
        },
        {
          "name": "3. Get Vehicle Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/vehicles/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["vehicles", "1"]
            }
          }
        },
        {
          "name": "4. Update Vehicle",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"capacity\": 6000}"
            },
            "url": {
              "raw": "http://localhost:3000/vehicles/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["vehicles", "1"]
            }
          }
        }
      ]
    },
